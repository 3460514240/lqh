    "import torch\n",
    "\n",
    "# 查看PyTorch版本\n",
    "print(f\"PyTorch版本: {torch.__version__}\")\n",
    "\n",
    "# 查看CUDA版本，如果PyTorch是带CUDA支持安装的话\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"CUDA版本: {torch.version.cuda}\")\n",
    "else:\n",
    "    print(\"CUDA不可用\")"
   ]
  }
